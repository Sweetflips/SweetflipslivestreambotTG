// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  VIEWER
  MOD
  OWNER
}

enum GameType {
  BONUS
  TRIVIA
  GUESS_BALANCE
  GUESS_BONUS
}

enum GameStatus {
  IDLE
  OPEN
  CLOSED
  REVEALED
}

enum RoundStatus {
  OPEN
  LOCKED
  CLOSED
}

model User {
  id            String    @id @default(cuid())
  telegramId    String?   @unique
  telegramUser  String?
  kickName      String?   @unique
  cwalletHandle String?
  role          Role      @default(VIEWER)
  linkedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  bonusEntries    BonusEntry[]
  triviaAnswers   TriviaAnswer[]
  scores          Score[]
  awards          Award[]
  linkCodes       LinkCode[]
  guesses         Guess[]
  auditLogs       AuditLog[]

  @@map("users")
}

model Game {
  id          String     @id @default(cuid())
  type        GameType
  status      GameStatus @default(IDLE)
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  bonusEntries  BonusEntry[]
  payouts       BonusPayout[]
  triviaRounds  TriviaRound[]
  scores        Score[]

  @@map("games")
}

model BonusEntry {
  id        String   @id @default(cuid())
  gameId    String
  userId    String
  guess     Int
  createdAt DateTime @default(now())

  // Relations
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
  @@map("bonus_entries")
}

model BonusPayout {
  id        String   @id @default(cuid())
  gameId    String
  name      String
  amountX   Int
  createdAt DateTime @default(now())

  // Relations
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@map("bonus_payouts")
}

model TriviaRound {
  id        String      @id @default(cuid())
  gameId    String
  question  String
  answer    String
  status    RoundStatus @default(OPEN)
  createdAt DateTime    @default(now())
  lockedAt  DateTime?

  // Relations
  game    Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  answers TriviaAnswer[]

  @@map("trivia_rounds")
}

model TriviaAnswer {
  id        String   @id @default(cuid())
  roundId   String
  userId    String
  answer    String
  isCorrect Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  round TriviaRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roundId, userId])
  @@map("trivia_answers")
}

model Score {
  id        String   @id @default(cuid())
  gameId    String
  userId    String
  points    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
  @@map("scores")
}

model Award {
  id          String    @id @default(cuid())
  userId      String
  gameId      String
  amount      Decimal
  currency    String    @default("USDT")
  status      String    @default("pending") // pending, sent, failed
  tipCommand  String?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("awards")
}

model LinkCode {
  id        String   @id @default(cuid())
  userId    String
  code      String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("link_codes")
}

model GameRound {
  id          String     @id @default(cuid())
  type        GameType
  phase       GameStatus @default(IDLE)
  finalValue  Int?
  graceWindow Int        @default(30) // seconds
  windowMin   Int        @default(0)  // minutes, 0 = manual close only
  minRange    Int        @default(1)
  maxRange    Int        @default(1000000)
  createdAt   DateTime   @default(now())
  closedAt    DateTime?
  revealedAt  DateTime?
  updatedAt   DateTime   @updatedAt

  // Relations
  guesses   Guess[]
  bonusItems BonusItem[]
  auditLogs AuditLog[]

  @@map("game_rounds")
}

model Guess {
  id        String   @id @default(cuid())
  gameRoundId String
  userId    String
  value     Int
  createdAt DateTime @default(now())
  editedAt  DateTime?

  // Relations
  gameRound GameRound @relation(fields: [gameRoundId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameRoundId, userId])
  @@map("guesses")
}

model BonusItem {
  id        String   @id @default(cuid())
  gameRoundId String
  name      String
  payoutX   Int?     // multiplier, null if not yet paid out
  createdAt DateTime @default(now())

  // Relations
  gameRound GameRound @relation(fields: [gameRoundId], references: [id], onDelete: Cascade)

  @@map("bonus_items")
}

model AuditLog {
  id        String   @id @default(cuid())
  gameRoundId String?
  userId    String
  command   String
  params    Json?
  createdAt DateTime @default(now())

  // Relations
  gameRound GameRound? @relation(fields: [gameRoundId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}
