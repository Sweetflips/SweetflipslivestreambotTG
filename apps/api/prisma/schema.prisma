// Simplified Prisma schema for SQLite
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  telegramId  String   @unique
  telegramUser String?
  kickName    String?
  role        String   @default("VIEWER") // "VIEWER", "MOD", "OWNER"
  linkedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  guesses     Guess[]
  auditLogs   AuditLog[]

  @@map("users")
}

model GameRound {
  id          String   @id @default(cuid())
  type        String   // "BONUS", "TRIVIA", "GUESS_BALANCE", "GUESS_BONUS"
  phase       String   @default("IDLE") // "IDLE", "OPEN", "CLOSED", "REVEALED", "COMPLETED"
  finalValue  Int?
  graceWindow Int      @default(30) // seconds
  windowMin   Int      @default(0)  // minutes, 0 = manual close only
  minRange    Int      @default(1)
  maxRange    Int      @default(1000000)
  createdAt   DateTime @default(now())
  closedAt    DateTime?
  revealedAt  DateTime?
  completedAt DateTime? // When the game round is fully completed and archived
  updatedAt   DateTime @updatedAt

  // Relations
  guesses   Guess[]
  bonusItems BonusItem[]
  auditLogs AuditLog[]

  @@map("game_rounds")
}

model Guess {
  id        String   @id @default(cuid())
  gameRoundId String
  userId    String
  value     Int
  createdAt DateTime @default(now())
  editedAt  DateTime?
  isArchived Boolean @default(false) // Whether this guess has been archived with a completed game

  // Relations
  gameRound GameRound @relation(fields: [gameRoundId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameRoundId, userId])
  @@unique([gameRoundId, value])
  @@map("guesses")
}

model BonusItem {
  id        String   @id @default(cuid())
  gameRoundId String
  name      String
  payoutX   Int?     // multiplier, null if not yet paid out
  createdAt DateTime @default(now())

  // Relations
  gameRound GameRound @relation(fields: [gameRoundId], references: [id], onDelete: Cascade)

  @@map("bonus_items")
}

model AuditLog {
  id        String   @id @default(cuid())
  gameRoundId String?
  userId    String
  command   String
  params    String?  // JSON as string instead of Json type
  createdAt DateTime @default(now())

  // Relations
  gameRound GameRound? @relation(fields: [gameRoundId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

// Legacy models for existing functionality
model BonusHunt {
  id        String   @id @default(cuid())
  isActive  Boolean  @default(false)
  guesses   String   @default("{}") // JSON as string
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bonus_hunts")
}

model TriviaGame {
  id        String   @id @default(cuid())
  isActive  Boolean  @default(false)
  questions String   @default("[]") // JSON as string
  answers   String   @default("{}") // JSON as string
  scores    String   @default("{}") // JSON as string
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("trivia_games")
}

model LinkCode {
  id        String   @id @default(cuid())
  code      String   @unique
  telegramId String
  kickName  String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("link_codes")
}

model TelegramGroup {
  id          String   @id @default(cuid())
  groupId     String   @unique // Telegram group ID (e.g., "-1001234567890")
  title       String?  // Group title
  type        String?  // "group" or "supergroup"
  memberCount Int?     // Number of members
  isActive    Boolean  @default(true) // Whether bot is still a member
  source      String?  // How the group was discovered: "manual", "auto", "environment"
  lastSeen    DateTime @default(now()) // Last time we confirmed bot membership
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("telegram_groups")
}

model Schedule {
  id          String   @id @default(cuid())
  dayOfWeek   Int      // 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  streamNumber Int     // 1 or 2 (7AM UTC or 5PM UTC)
  eventTitle  String   // Title of the stream/event
  isActive    Boolean  @default(true) // Whether this schedule entry is active
  createdBy   String?  // User ID who created this schedule entry
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([dayOfWeek, streamNumber])
  @@map("schedules")
}

// Archive table for completed game rounds and their data
model CompletedGameArchive {
  id          String   @id @default(cuid())
  originalGameRoundId String @unique // Reference to the original game round
  gameType    String   // "BONUS", "TRIVIA", "GUESS_BALANCE", "GUESS_BONUS"
  finalValue  Int?
  totalGuesses Int     @default(0)
  winnerUserId String? // ID of the winning user
  winnerGuess  Int?    // The winning guess value
  gameData    String   // JSON string containing all game data (guesses, results, etc.)
  completedAt DateTime @default(now())
  archivedAt  DateTime @default(now())

  @@map("completed_game_archives")
}