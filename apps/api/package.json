{
  "name": "@sweetflips/api",
  "version": "1.0.0",
  "description": "SweetflipsStreamBot API service",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/dev.ts",
    "build": "tsc && tsc-alias",
    "start": "npx prisma generate && npx prisma db push --force-reset && node ../bot/bot.js",
    "start:with-db": "node start-with-db.js",
    "start:with-migration": "node scripts/start-with-migration.js",
    "migrate": "node scripts/ensure-database-schema.js",
    "fix-db": "node scripts/fix-sweet-calls-round-schema.js",
    "railway-fix": "node scripts/railway-fix-db.js",
    "migrate:auto": "node scripts/auto-migrate.js",
    "migrate:health": "node scripts/migration-health-check.js",
    "migrate:rollback": "node scripts/migration-rollback.js",
    "migrate:postgresql": "node scripts/postgresql-migration.js",
    "delete:sweet-calls": "node scripts/delete-sweet-calls-tables.js",
    "railway:delete-tables": "node scripts/railway-delete-tables.js",
    "railway:deploy": "node scripts/railway-postgresql-deploy.js",
    "health-check": "node scripts/health-check.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "node deploy-db.js",
    "db:init": "node init-db.js",
    "prisma:seed": "tsx src/prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.0",
    "fastify": "^4.24.0",
    "googleapis": "^160.0.0",
    "ioredis": "^5.3.0",
    "node-cron": "^3.0.3",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "socket.io": "^4.7.0",
    "telegraf": "^4.15.0",
    "ws": "^8.14.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.55.0",
    "prisma": "^5.7.0",
    "supertest": "^6.3.0",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
