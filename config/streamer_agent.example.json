{
  "relay": {
    "base_url": "http://127.0.0.1:8000",
    "source_name": "streamer-pc",
    "timeout_secs": 5.0,
    "retry_backoff_secs": 3.0,
    "health_check_on_start": true,
    "include_ws_metrics": true,
    "include_ws_segments": true,
    "emotion_laughter": false
  },
  "audio": {
    "device": null,
    "samplerate": 16000,
    "channels": 1,
    "dtype": "float32",
    "chunk_duration_secs": 0.8,
    "stride_secs": 0.25,
    "max_buffer_secs": 8.0,
    "min_transcribe_rms": 0.014
  },
  "whisper": {
    "model_size": "large-v3",
    "device": "cuda",
    "compute_type": "int8",
    "cpu_threads": 4,
    "num_workers": 1,
    "beam_size": 1,
    "best_of": 1,
    "patience": 1.0,
    "vad_filter": true,
    "vad_threshold": 0.5,
    "min_speech_duration_ms": 0,
    "min_silence_duration_ms": 250,
    "speech_pad_ms": 80,
    "condition_on_previous_text": false,
    "language": "en",
    "word_timestamps": false,
    "repetition_penalty": 1.15,
    "no_repeat_ngram_size": 3,
    "no_speech_threshold": 0.68,
    "log_prob_threshold": -0.32,
    "initial_prompt": "",
    "hotwords": ""
  },
  "transcript_filter": {
    "drop_avg_no_speech_above": 0.45,
    "drop_max_no_speech_above": 0.75,
    "combo_avg_no_speech_above": 0.26,
    "combo_avg_logprob_below": -0.62,
    "drop_compression_ratio_above": 2.75
  },
  "obs": {
    "enabled": true,
    "require_stream_active": true,
    "host": "127.0.0.1",
    "port": 4455,
    "password": "",
    "poll_interval_secs": 2.0
  },
  "dedup_window_secs": 8.0,
  "min_text_chars": 2,
  "log_path": "logs/streamer_agent.log",
  "log_level": "INFO"
}
