// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  telegramId  String   @unique
  telegramUser String?
  kickName    String?  @unique
  role        String   @default("VIEWER")
  linkedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  guesses   Guess[]
  auditLogs AuditLog[]

  @@map("users")
}

model Guess {
  id        String   @id @default(cuid())
  userId    String
  gameType  String   // "balance" or "bonus"
  guess     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameType])
  @@map("guesses")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   String?
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model TelegramGroup {
  id          String   @id @default(cuid())
  groupId     String   @unique // Telegram group ID (e.g., "-1001234567890")
  title       String?  // Group title
  type        String?  // "group" or "supergroup"
  memberCount Int?     // Number of members
  isActive    Boolean  @default(true) // Whether bot is still a member
  source      String?  // How the group was discovered: "manual", "auto", "environment"
  lastSeen    DateTime @default(now()) // Last time we confirmed bot membership
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("telegram_groups")
}