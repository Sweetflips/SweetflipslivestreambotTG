// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  telegramId  String   @unique
  telegramUser String?
  kickName    String?  @unique
  role        String   @default("VIEWER")
  linkedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  guesses   Guess[]
  auditLogs AuditLog[]
  sweetCalls SweetCall[]

  @@map("users")
}

model GameRound {
  id          String   @id @default(cuid())
  type        String   // "BONUS", "TRIVIA", "GUESS_BALANCE", "GUESS_BONUS"
  phase       String   @default("IDLE") // "IDLE", "OPEN", "CLOSED", "REVEALED"
  finalValue  Int?
  graceWindow Int      @default(30) // seconds
  windowMin   Int      @default(0)  // minutes, 0 = manual close only
  minRange    Int      @default(1)
  maxRange    Int      @default(1000000)
  createdAt   DateTime @default(now())
  closedAt    DateTime?
  revealedAt  DateTime?
  updatedAt   DateTime @updatedAt

  // Relations
  guesses   Guess[]
  bonusItems BonusItem[]
  auditLogs AuditLog[]

  @@map("game_rounds")
}

model Guess {
  id        String   @id @default(cuid())
  gameRoundId String
  userId    String
  value     Int
  createdAt DateTime @default(now())
  editedAt  DateTime?

  // Relations
  gameRound GameRound @relation(fields: [gameRoundId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameRoundId, userId])
  @@unique([gameRoundId, value])
  @@map("guesses")
}

model BonusItem {
  id        String   @id @default(cuid())
  gameRoundId String
  name      String
  payoutX   Int?     // multiplier, null if not yet paid out
  createdAt DateTime @default(now())

  // Relations
  gameRound GameRound @relation(fields: [gameRoundId], references: [id], onDelete: Cascade)

  @@map("bonus_items")
}

// Archive functionality removed for simplicity - using basic database storage

model AuditLog {
  id        String   @id @default(cuid())
  gameRoundId String?
  sweetCallsRoundId String?
  userId    String
  command   String
  params    String?  // JSON as string instead of Json type
  createdAt DateTime @default(now())

  // Relations
  gameRound GameRound? @relation(fields: [gameRoundId], references: [id], onDelete: Cascade)
  sweetCallsRound SweetCallsRound? @relation(fields: [sweetCallsRoundId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model TelegramGroup {
  id          String   @id @default(cuid())
  groupId     String   @unique // Telegram group ID (e.g., "-1001234567890")
  title       String?  // Group title
  type        String?  // "group" or "supergroup"
  memberCount Int?     // Number of members
  isActive    Boolean  @default(true) // Whether bot is still a member
  source      String?  // How the group was discovered: "manual", "auto", "environment"
  lastSeen    DateTime @default(now()) // Last time we confirmed bot membership
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("telegram_groups")
}

model Schedule {
  id           String   @id @default(cuid())
  dayOfWeek    Int      // 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  streamNumber Int      // 1 or 2 (for different stream times)
  eventTitle   String   // Title of the stream event
  isActive     Boolean  @default(true) // Whether this schedule entry is active
  createdBy    String?  // User ID who created this entry
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([dayOfWeek, streamNumber])
  @@map("schedules")
}

model StreamNotification {
  id           String   @id @default(cuid())
  dayOfWeek    Int      // 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  streamNumber Int      // 1 or 2 (for different stream times)
  notificationType String // "2hour_reminder", "schedule_broadcast", etc.
  sentAt       DateTime @default(now())
  eventDate    DateTime // The actual date of the stream event
  successCount Int      @default(0) // Number of groups successfully notified
  failedCount  Int      @default(0) // Number of groups that failed

  @@unique([dayOfWeek, streamNumber, notificationType, eventDate])
  @@map("stream_notifications")
}

model SweetCallsRound {
  id          String   @id @default(cuid())
  phase       String   @default("IDLE") // "IDLE", "OPEN", "CLOSED", "REVEALED"
  createdAt   DateTime @default(now())
  closedAt    DateTime?
  revealedAt  DateTime?
  updatedAt   DateTime @updatedAt

  // Relations
  calls       SweetCall[]
  auditLogs   AuditLog[]

  @@map("sweet_calls_rounds")
}

model SweetCall {
  id        String   @id @default(cuid())
  roundId   String
  userId    String
  slotName  String
  multiplier Float?  // Outcome multiplier for this slot (set by MOD/Owner)
  createdAt DateTime @default(now())
  isArchived Boolean @default(false) // Whether this call has been archived with a completed round

  // Relations
  round     SweetCallsRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roundId, userId]) // Each user can only call once per round
  @@unique([roundId, slotName]) // Each slot can only be called once per round
  @@map("sweet_calls")
}
