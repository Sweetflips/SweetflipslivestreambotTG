# Copy to ".env" on the streamer PC (never commit .env).
#
# Relay: outbound HTTPS only (no inbound ports on this machine)
# JSON streamer agent: same host as relay.base_url; overrides JSON if set
STT_RELAY_URL=http://62.45.124.91:8766
STT_SOURCE_NAME=streamer-pc
# STT_HTTP_TIMEOUT_S=10
# STT_HTTP_POST_MAX_RETRIES=5
# STT_HTTP_POST_BACKOFF_MAX_S=30
# STT_LOG_LEVEL=INFO

# Whisper (streamer_agent)
STT_MODEL=large-v3
# STT_MODEL=large-v3-turbo
STT_COMPUTE_TYPE=float16
STT_LANGUAGE=en
# STT_MULTILINGUAL=0
# STT_BEAM_SIZE=1
# STT_CPU_THREADS=4
# STT_VOICE_EMOTION=0

# Microphone: use NVIDIA Broadcast virtual device (RODE/other mic is chosen inside the NVIDIA Broadcast app)
# STT_NVIDIA_BROADCAST_MIC_ONLY=1
# Or pin one device by exact Windows name from STT_LIST_DEVICES=1:
# STT_INPUT_DEVICE_EXACT_NAME=Microfoon (NVIDIA Broadcast)
# STT_INPUT_DEVICE_INDEX=
# STT_LIST_DEVICES=1

# OBS (stream start/stop toggles transcription)
OBS_WS_ENABLED=1
OBS_WS_HOST=localhost
OBS_WS_PORT=4455
OBS_WS_PASSWORD=your_obs_websocket_password
# OBS_POLL_INTERVAL_S=1

# --- Optional: WebSocket listener debug (listen_stt_ws.py) / relay server ---
# STT_WS_TOKEN=
# STT_PUBLIC_HOST=stt.sweetflips.ai
# STT_WS_URL=wss://stt.sweetflips.ai/ws/stt
