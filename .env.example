# Copy to ".env" on the streamer PC (never commit .env).
#
# --- STT relay (same host for HTTP /health and WebSocket /ws/stt) ---
# HTTP base URL: used for GET /health; WebSocket URL is derived as ws(s)://same-host/ws/stt
# unless STT_WS_URL is set.
STT_RELAY_URL=http://127.0.0.1:8000
# Shared secret with relay_server.py (query ?token=...). Required unless relay uses STT_ALLOW_OPEN_WS=1.
STT_WS_TOKEN=your_shared_websocket_secret
# Optional: full WebSocket URL (overrides ws:// derived from STT_RELAY_URL). role=streamer added if missing.
# STT_WS_URL=wss://stt.example.com/ws/stt
# Optional: listener-visible stream id (defaults to relay.source_name in JSON config)
# STT_STREAM_ID=streamer-pc

# Legacy name used in some configs (same as STT_RELAY_URL if set)
# RELAY_BASE_URL=

# STT_HTTP_TIMEOUT_S=10
# STT_LOG_LEVEL=INFO

# Whisper (streamer_agent)
STT_MODEL=large-v3
# STT_MODEL=large-v3-turbo
STT_COMPUTE_TYPE=float16
STT_LANGUAGE=en
# STT_MULTILINGUAL=0
# STT_BEAM_SIZE=1
# STT_CPU_THREADS=4
# STT_VOICE_EMOTION=0

# Microphone: use NVIDIA Broadcast virtual device (RODE/other mic is chosen inside the NVIDIA Broadcast app)
# STT_NVIDIA_BROADCAST_MIC_ONLY=1
# Or pin one device by exact Windows name from STT_LIST_DEVICES=1:
# STT_INPUT_DEVICE_EXACT_NAME=Microfoon (NVIDIA Broadcast)
# STT_INPUT_DEVICE_INDEX=
# STT_LIST_DEVICES=1

# OBS (optional: only transcribe while OBS reports stream active — see JSON obs.require_stream_active)
OBS_WS_ENABLED=1
OBS_WS_HOST=localhost
OBS_WS_PORT=4455
OBS_WS_PASSWORD=your_obs_websocket_password
# OBS_POLL_INTERVAL_S=1
