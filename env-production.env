# ===========================================
# SWEETFLIPS LIVESTREAM BOT - ENVIRONMENT VARIABLES
# ===========================================

# 🤖 TELEGRAM BOT CONFIGURATION
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=8422817933:AAHm0YU707fnBeuehr-QrFJD-4A9M6aTCPc

# 📊 DATABASE CONFIGURATION
# For Railway deployment, this will be automatically provided
# For local development, use SQLite
DATABASE_URL="file:./dev.db"

# 🔴 LIVE BALANCE API CONFIGURATION
# Bearer token for live balance API integration
LIVE_BALANCE_BEARER_TOKEN=your_bearer_token_here

# 📋 GOOGLE SHEETS CONFIGURATION
# Google Sheets ID for account syncing and data storage
GOOGLE_SPREADSHEET_ID=1giec5bb4Pmjywhfn_oy3aIESJ25XHi5kDwjXyoQbglQ
GOOGLE_SHEETS_ID=1giec5bb4Pmjywhfn_oy3aIESJ25XHi5kDwjXyoQbglQ

# 🔑 GOOGLE SERVICE ACCOUNT
# Path to your Google service account key file
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./credentials/service-account-key.json

# 🌍 ENVIRONMENT SETTINGS
# Set to 'production' for Railway deployment, 'development' for local
NODE_ENV=development

# 🔗 WEBHOOK CONFIGURATION (for production)
# Railway will provide this automatically
# TELEGRAM_WEBHOOK_URL=https://your-railway-app.railway.app/webhook/telegram

# 👥 TELEGRAM GROUP CONFIGURATION
# Group IDs for mod and payout notifications (optional)
# TELEGRAM_MOD_GROUP_ID=-1001234567890
# TELEGRAM_PAYOUT_GROUP_ID=-1001234567891

# 🔐 SECURITY & ENCRYPTION (for API version)
# These are generated automatically in production
# JWT_SECRET=your_jwt_secret_here
# ENCRYPTION_KEY=your_encryption_key_here

# 📈 REDIS CONFIGURATION (for API version)
# Railway provides this automatically
# REDIS_URL=redis://localhost:6379

# ===========================================
# DEPLOYMENT NOTES:
# ===========================================
# 1. For Railway deployment, only these are required:
#    - TELEGRAM_BOT_TOKEN
#    - DATABASE_URL (auto-provided)
#    - NODE_ENV=production
#
# 2. For local development, use:
#    - TELEGRAM_BOT_TOKEN
#    - DATABASE_URL="file:./dev.db"
#    - NODE_ENV=development
#
# 3. Google Sheets integration requires:
#    - GOOGLE_SPREADSHEET_ID
#    - GOOGLE_SERVICE_ACCOUNT_KEY_FILE
#
# 4. Live balance features require:
#    - LIVE_BALANCE_BEARER_TOKEN
# ===========================================

