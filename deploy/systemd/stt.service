[Unit]
Description=STT WebSocket relay (FastAPI, localhost only)
After=network.target

[Service]
Type=simple
User=stt
Group=stt
WorkingDirectory=/opt/stt
EnvironmentFile=-/etc/stt.env
ExecStart=/opt/stt/.venv/bin/python -m uvicorn relay_server:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
